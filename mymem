#!/usr/bin/env python3
"""mymem — one provider-agnostic CLI for the mymemories system.

  mymem dream   [--partition P] [--provider claude|codex] [--dry-run] [--since D] [--no-push]
  mymem link    [--partition P | --project PATH] [--provider ...]   # expose a partition to a harness
  mymem install [--provider ...]                                    # link every partition in the manifest
  mymem providers                                                   # list detected providers

Provider is auto-detected (claude, then codex) unless --provider / MYMEM_PROVIDER
is given. All memory lives in $MEM_HOME (default ~/workplace/mymemories).
"""
import sys, os, argparse, datetime, json

# Make `memcore` importable whether run from the repo or an integration copy.
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from memcore import store, dream as dreamer, providers, codex_import  # noqa: E402

STATE_FILE = os.path.join(store.MEM_HOME, ".dream-state.json")


def _load_state():
    try:
        return json.load(open(STATE_FILE))
    except (FileNotFoundError, ValueError):
        return {}


def _save_state(s):
    json.dump(s, open(STATE_FILE, "w"), indent=2)


def _now():
    return datetime.datetime.now().timestamp()


def _stamp():
    return datetime.datetime.now().strftime("%Y%m%dT%H%M%S")


def _partition_for_project(project_abs):
    for part, proj in store.read_manifest():
        if os.path.realpath(proj) == os.path.realpath(project_abs):
            return part
    return None


def cmd_dream(args, provider):
    if not os.path.isdir(store.MEM_HOME):
        sys.exit(f"MEM_HOME not found: {store.MEM_HOME}")
    stamp = _stamp()
    state = _load_state()
    since_override = (datetime.datetime.strptime(args.since, "%Y-%m-%d").timestamp()
                      if args.since else None)
    if not args.dry_run:
        store.git_pull()
    for partition, project_abs in store.read_manifest():
        if args.partition and partition != args.partition:
            continue
        since_ts = since_override if since_override is not None else state.get(partition)
        dreamer.consolidate(provider, partition, project_abs, since_ts, stamp,
                            args.dry_run, model=args.model, push=not args.no_push)
        if not args.dry_run:
            state[partition] = _now()
            _save_state(state)
    print("[mymem] dream done")


def cmd_codex_import(args, provider):
    """Import Codex's native memories into the shared store (via the consolidator)."""
    if not os.path.isdir(store.MEM_HOME):
        sys.exit(f"MEM_HOME not found: {store.MEM_HOME}")
    stamp = _stamp()
    if not args.dry_run:
        store.git_pull()
    # Always use the Codex provider's model for judging Codex-sourced memories,
    # unless the user forced a provider explicitly.
    codex_import.run(provider, stamp, args.dry_run, model=args.model,
                     push=not args.no_push, only_partition=args.partition)
    print("[mymem] codex-import done")


def cmd_save(args, provider):
    """Write one fact into a partition and sync (pull -> write -> commit -> push).
    Deterministic: no LLM. Used by /memorize-style skills on any provider."""
    if not os.path.isdir(store.MEM_HOME):
        sys.exit(f"MEM_HOME not found: {store.MEM_HOME}")
    if not store.safe_slug(args.slug):
        sys.exit(f"unsafe slug: {args.slug!r} (use lowercase kebab/snake)")
    # resolve partition: explicit, else by --project, else cwd
    part = args.partition
    if not part:
        proj = os.path.abspath(os.path.expanduser(args.project)) if args.project else os.getcwd()
        part = _partition_for_project(proj)
    if not part:
        sys.exit("could not resolve a partition; pass --partition or --project")
    if not os.path.isdir(store.partition_dir(part)):
        sys.exit(f"partition {part!r} has no dir in {store.MEM_HOME}")
    # read content: --content, else stdin
    content = args.content if args.content is not None else sys.stdin.read()
    if not content.strip():
        sys.exit("empty content (pass --content or pipe via stdin)")
    if args.dry_run:
        print(f"[mymem] DRY-RUN: would save {part}/{args.slug}.md (no write, no commit)")
        return
    if not args.no_pull:
        store.git_pull()
    store.write_fact(part, args.slug, args.type, args.description, content,
                     args.evidence or "manual", origin=args.origin)
    store.regen_memory_index(part)
    msg = f"mem: {args.slug} ({part})"
    committed = store.commit_partition(part, msg, push=not args.no_push)
    print(f"[mymem] saved {part}/{args.slug}.md" + (" + pushed" if committed and not args.no_push
          else " + committed" if committed else " (no git change)"))


def cmd_link(args, provider):
    if args.project:
        project = os.path.abspath(os.path.expanduser(args.project))
        part = _partition_for_project(project) or args.partition
        if not part:
            # Silent no-op: the SessionStart hook calls this on every project,
            # most of which have no partition. Not an error.
            return
        print("linked:", provider.link(part, project))
        return
    # link a named partition using its manifest project path
    for partition, project_abs in store.read_manifest():
        if args.partition and partition != args.partition:
            continue
        print(f"linked {partition}:", provider.link(partition, project_abs))


def cmd_install(args, provider):
    n = skipped = 0
    for partition, project_abs in store.read_manifest():
        try:
            where = provider.link(partition, project_abs)
        except OSError as e:
            print(f"skip {partition}: {e}"); skipped += 1; continue
        if where:
            print(f"linked {partition} -> {where}"); n += 1
        else:
            print(f"skip {partition}: project dir not present"); skipped += 1
    print(f"[mymem] linked {n} partition(s) for provider {provider.name}"
          + (f" ({skipped} skipped)" if skipped else ""))


def cmd_providers(_args, _provider):
    for name, cls in providers.PROVIDERS.items():
        p = cls()
        print(f"{name:8} {'available' if p.available() else 'not detected'}")


def main():
    ap = argparse.ArgumentParser(prog="mymem", description="Provider-agnostic memory for coding agents.")
    ap.add_argument("--provider", choices=list(providers.PROVIDERS), help="override auto-detection")
    sub = ap.add_subparsers(dest="cmd", required=True)

    d = sub.add_parser("dream", help="consolidate memory from recent transcripts")
    d.add_argument("--partition")
    d.add_argument("--dry-run", action="store_true")
    d.add_argument("--since", help="YYYY-MM-DD; override the per-partition watermark")
    d.add_argument("--model", help="model alias for the provider's headless call")
    d.add_argument("--no-push", action="store_true", help="commit locally but don't push")
    d.set_defaults(func=cmd_dream)

    ci = sub.add_parser("codex-import", help="import Codex's native memories into the shared store")
    ci.add_argument("--partition", help="only this partition")
    ci.add_argument("--dry-run", action="store_true")
    ci.add_argument("--model", help="model alias for the headless judging call")
    ci.add_argument("--no-push", action="store_true")
    ci.set_defaults(func=cmd_codex_import)

    sv = sub.add_parser("save", help="write one fact into a partition and sync (no LLM)")
    sv.add_argument("slug", help="kebab-case memory slug")
    sv.add_argument("--content", help="fact body (else read from stdin)")
    sv.add_argument("--description", default="", help="one-line index hook")
    sv.add_argument("--type", default="reference", choices=["user", "feedback", "project", "reference"])
    sv.add_argument("--partition", help="target partition (else resolved from --project/cwd)")
    sv.add_argument("--project", help="resolve partition from this project path")
    sv.add_argument("--evidence", help="session id or source (default: manual)")
    sv.add_argument("--origin", default="memorize")
    sv.add_argument("--dry-run", action="store_true")
    sv.add_argument("--no-pull", action="store_true", help="skip git pull before writing")
    sv.add_argument("--no-push", action="store_true", help="commit locally but don't push")
    sv.set_defaults(func=cmd_save)

    l = sub.add_parser("link", help="expose a partition so the harness auto-loads it")
    l.add_argument("--partition")
    l.add_argument("--project", help="link the partition for this project path")
    l.set_defaults(func=cmd_link)

    i = sub.add_parser("install", help="link every partition in the manifest")
    i.set_defaults(func=cmd_install)

    p = sub.add_parser("providers", help="list detected providers")
    p.set_defaults(func=cmd_providers)

    args = ap.parse_args()
    provider = providers.get_provider(args.provider)
    args.func(args, provider)


if __name__ == "__main__":
    main()
